FROM node:22-bookworm-slim

WORKDIR /app

RUN corepack enable

# Install CLI providers used by Claw-Empire agent runtime
RUN npm install -g \
  @anthropic-ai/claude-code \
  @openai/codex \
  @google/gemini-cli \
  opencode

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

COPY . .
RUN pnpm build

EXPOSE 8790

CMD ["pnpm", "start:tailscale"]
